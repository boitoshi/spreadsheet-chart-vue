# Caddy リバースプロキシ設定
# ドメイン名は環境に合わせて変更すること
{$DOMAIN:dashboard.example.com} {
    reverse_proxy localhost:3000
    encode gzip

    log {
        output file /var/log/caddy/access.log
        format json
    }

    # セキュリティヘッダー
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }
}
