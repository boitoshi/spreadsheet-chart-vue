# === 必須 ===
SPREADSHEET_ID=（スプレッドシートIDをここに設定）
GOOGLE_APPLICATION_CREDENTIALS=/app/portfolio-dashboard/collector/config/my-service-account.json
DB_PATH=/app/portfolio-dashboard/data/portfolio.db

# === WordPress 自動投稿（任意）===
WP_URL=https://your-blog.com
WP_USER=your-wp-username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx
WP_PUBLISH_ENABLED=false

# === AI コメント生成（任意）===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
AI_COMMENTS_ENABLED=false
